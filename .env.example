# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_EXTERNAL_BOOTSTRAP_SERVERS=localhost:29092
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Spark Configuration
SPARK_MASTER_URL=spark://spark-master:7077
CHECKPOINT_LOCATION=/tmp/delta/_checkpoints

# Storage Configuration
DELTA_BRONZE_PATH=/tmp/delta/bronze
DELTA_SILVER_PATH=/tmp/delta/silver
DELTA_GOLD_PATH=/tmp/delta/gold

# Redis (Feast Online Store)
REDIS_HOST=redis
REDIS_PORT=6379

# Airflow Configuration
AIRFLOW_DB_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow

# Data Platform Environment
ENV=production
LOG_LEVEL=INFO
